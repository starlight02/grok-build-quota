# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Cargo.lock is committed: this crate ships a binary, so a pinned lockfile
# keeps builds reproducible. See
# https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Node / tooling
node_modules/
style/uno.css

# Playwright end-to-end artifacts
end2end/playwright-report/
end2end/test-results/

# Local scratch, review notes, ad-hoc harnesses
tmp/
examples/

.DS_Store
