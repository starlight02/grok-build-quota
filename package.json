{
  "name": "grok-build-quota",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "css": "unocss \"src/**/*.rs\" -o style/uno.css",
    "css:watch": "unocss \"src/**/*.rs\" -o style/uno.css --watch",
    "dev:css": "pnpm run css:watch",
    "predev": "pnpm run css",
    "dev": "concurrently -k -n css,leptos -c magenta,cyan \"pnpm run css:watch\" \"cargo leptos watch\"",
    "prebuild": "pnpm run css",
    "build": "cargo leptos build --release",
    "fmt": "leptosfmt src && cargo fmt",
    "fmt:check": "leptosfmt --check src && cargo fmt --check",
    "lint": "cargo clippy --all-targets -- -D warnings",
    "check": "pnpm run fmt:check && pnpm run lint",
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && lefthook install || true"
  },
  "devDependencies": {
    "@unocss/cli": "^66.7.5",
    "concurrently": "^10.0.3",
    "lefthook": "^2.1.9",
    "unocss": "^66.7.5"
  }
}
